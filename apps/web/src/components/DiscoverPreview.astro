---
import CategoryIcon from './CategoryIcon.astro';

/**
 * Six entries from the curated Discover list — drawn straight from
 * apps/desktop/src/main/discover/curated.json (16 total). Ordered to
 * lead with the most-recognized plugins, then a couple of Anthropic
 * official skills to show the breadth.
 *
 * Keep in sync with curated.json on cosmetic edits — the verified
 * source of truth lives in the desktop app.
 */
const ENTRIES = [
  {
    cat: 'plugin',
    name: 'Superpowers',
    maintainer: 'obra',
    why: 'Brainstorm, plan, build, ship — the most-installed plugin in the ecosystem.',
  },
  {
    cat: 'plugin',
    name: 'claude-mem',
    maintainer: 'thedotmack',
    why: 'Cross-session memory. Solves the cold-start problem on long projects.',
  },
  {
    cat: 'plugin',
    name: 'gstack',
    maintainer: 'garrytan',
    why: '23 opinionated tools — CEO, Designer, Eng Manager, Doc Engineer, QA.',
  },
  {
    cat: 'skill',
    name: 'Skill Creator',
    maintainer: 'anthropics',
    why: 'Official skill for writing new skills. Scaffold, evals, and feedback loop.',
  },
  {
    cat: 'skill',
    name: 'MCP Builder',
    maintainer: 'anthropics',
    why: 'Build ship-quality MCP servers with the patterns Anthropic uses internally.',
  },
  {
    cat: 'skill',
    name: 'PDF',
    maintainer: 'anthropics',
    why: 'Read, write, edit, merge, split, and fill PDF forms — Anthropic\'s canonical PDF skill.',
  },
] as const;
---

<div>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      ENTRIES.map((entry) => (
        <article class="card-lift rounded-lg border border-border bg-surface p-4 hover:bg-surface-raised hover:border-border-subtle">
          <div class="mb-3 flex items-start justify-between gap-3">
            <CategoryIcon category={entry.cat as never} size={32} />
          </div>
          <h3 class="text-md font-semibold tracking-tight text-text">{entry.name}</h3>
          <p class="mt-1 line-clamp-2 text-sm text-muted">{entry.why}</p>
          <div class="mt-3 flex items-center gap-1.5">
            <span
              class:list={[
                'inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold tracking-wide',
                entry.cat === 'plugin' && 'bg-[#581C87] text-[#d8b4fe]',
                entry.cat === 'skill' && 'bg-[#78350F] text-[#fcd34d]',
              ]}
            >
              {entry.cat === 'plugin' ? 'Plugin' : 'Skill'}
            </span>
            <span class="inline-flex items-center rounded-full bg-surface-raised px-2 py-0.5 font-mono text-[10px] text-muted">
              {entry.maintainer}
            </span>
          </div>
        </article>
      ))
    }
  </div>

  <p class="mt-6 text-sm text-subtle">
    16 entries in the Discover tab today — every URL and subdirectory
    verified against the GitHub API at curation time. Add more via PR.
  </p>
</div>
