---
const POINTS = [
  'Reads your config locally — never leaves your machine',
  'No accounts, no telemetry, no analytics, no crash reporting',
  'Every write snapshots the source first, atomic, never tears the file',
  'Open source, MIT — auditable end-to-end',
] as const;
---

<div class="rounded-xl border border-border bg-surface p-8 sm:p-10">
  <div class="flex flex-col gap-8 md:flex-row md:items-start">
    <div class="flex-shrink-0">
      <div class="grid h-12 w-12 place-items-center rounded-lg bg-accent/15 text-accent">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
    </div>
    <div class="flex-1">
      <h3 class="text-xl font-semibold tracking-tight text-text sm:text-2xl">
        Local-first. Your config never leaves your machine.
      </h3>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted">
        Bridge is a trust product. It touches <span class="font-mono text-sm">~/.claude.json</span>{' '}
        and <span class="font-mono text-sm">~/.claude/</span> — that contract isn't optional.
      </p>
      <ul class="mt-6 space-y-3">
        {
          POINTS.map((point) => (
            <li class="flex items-start gap-3 text-sm text-muted sm:text-base">
              <span class="mt-1 grid h-4 w-4 flex-shrink-0 place-items-center rounded-full bg-success/15 text-success">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              {point}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
