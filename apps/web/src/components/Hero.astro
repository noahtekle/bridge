---
const RELEASES_URL = 'https://github.com/noahtekle/bridge/releases';
const REPO_URL = 'https://github.com/noahtekle/bridge';
---

<section class="relative isolate overflow-hidden">
  {/* Grid backdrop — masked to a soft radial fade so it sets atmosphere without competing for attention. */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[680px] opacity-[0.18]"
    style="background-image: linear-gradient(to right, rgba(255,255,255,0.10) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.10) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 70% 60% at 50% 0%, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 0%, black 30%, transparent 80%);"
  >
  </div>

  {/* Drifting gradient blobs — visibly atmospheric. GPU-only, no layout cost. */}
  <div
    aria-hidden="true"
    class="blob-a pointer-events-none absolute -left-32 top-10 -z-10 h-[460px] w-[460px] rounded-full blur-[100px]"
    style="background: radial-gradient(circle, #3B82F6 0%, transparent 70%);"
  >
  </div>
  <div
    aria-hidden="true"
    class="blob-b pointer-events-none absolute -right-24 top-40 -z-10 h-[520px] w-[520px] rounded-full blur-[110px]"
    style="background: radial-gradient(circle, #A855F7 0%, transparent 70%);"
  >
  </div>

  <div class="mx-auto w-full max-w-5xl px-6 pb-16 pt-20 sm:pt-28">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="hero-rise hero-rise-1 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
          <span class="status-pulse h-1.5 w-1.5 rounded-full bg-success" aria-hidden="true"></span>
          v0.1 — pre-release
        </span>
        <h1
          class="hero-rise hero-rise-2 title-sheen mt-6 pb-1 text-4xl font-bold leading-tight tracking-tight sm:text-5xl"
          style="text-wrap: balance;"
        >
          The OS for Claude Code.
        </h1>
        <p class="hero-rise hero-rise-3 mt-5 max-w-xl text-lg leading-relaxed text-muted">
          See, manage, and install every MCP, Skill, Agent, Plugin, slash command, and hook in your
          Claude Code stack — from one local-first dashboard.
        </p>

        <div class="hero-rise hero-rise-4 mt-8 flex flex-wrap items-center gap-3">
          <a
            href={RELEASES_URL}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-2 rounded-md bg-text px-5 py-2.5 text-sm font-medium text-bg transition-all duration-200 hover:bg-text/90 hover:-translate-y-0.5"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            Download for Mac
          </a>
          <a
            href={RELEASES_URL}
            target="_blank"
            rel="noreferrer"
            class="flex items-center gap-2 rounded-md border border-border bg-surface px-5 py-2.5 text-sm font-medium text-text transition-all duration-200 hover:bg-surface-raised hover:-translate-y-0.5"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M0 3.449L9.75 2.1v9.451H0V3.449zM10.949 1.949L24 0v11.4H10.949V1.949zM0 12.6h9.75v9.451L0 20.699V12.6zM10.949 12.699H24V24l-13.051-1.851V12.699z"/>
            </svg>
            Download for Windows
          </a>
          <a
            href={REPO_URL}
            target="_blank"
            rel="noreferrer"
            class="group flex items-center gap-2 px-3 py-2 text-sm text-muted transition-colors duration-200 hover:text-text"
          >
            View on GitHub
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            >
              <path d="M7 17L17 7" />
              <polyline points="7 7 17 7 17 17" />
            </svg>
          </a>
        </div>

        <p class="hero-rise hero-rise-4 mt-5 text-xs text-subtle">
          Mac and Windows. Unsigned for v0.1 — first launch shows a security prompt; Bridge is
          open source, you can audit before approving. <a
            href={`${REPO_URL}#why-is-this-unsigned`}
            target="_blank"
            rel="noreferrer"
            class="underline-offset-2 hover:underline"
          >
            Why?
          </a>
        </p>
      </div>

      <div class="hero-rise hero-rise-3 lg:justify-self-end">
        <div class="overflow-hidden rounded-xl border border-border bg-surface shadow-2xl shadow-black/40 ring-1 ring-white/5">
          <img
            src="/dashboard.png"
            alt="Bridge dashboard showing 107 items across MCPs, Plugins, Skills, Agents, Commands, and Hooks"
            width="1280"
            height="800"
            loading="eager"
            fetchpriority="high"
            class="block w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>
</section>
