---
const REPO = 'https://github.com/noahtekle/bridge';
---

<footer class="border-t border-border-subtle">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-3 px-6 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <span class="text-md font-semibold tracking-tight text-text">Bridge</span>
      <span class="text-sm text-subtle">— The OS for Claude Code.</span>
    </div>
    <div class="flex items-center gap-5 text-sm text-muted">
      <a
        href={REPO}
        target="_blank"
        rel="noreferrer"
        class="transition-colors duration-200 hover:text-text"
      >
        GitHub
      </a>
      <a
        href={`${REPO}/blob/main/LICENSE`}
        target="_blank"
        rel="noreferrer"
        class="transition-colors duration-200 hover:text-text"
      >
        MIT license
      </a>
      <a
        href={`${REPO}/blob/main/CHANGELOG.md`}
        target="_blank"
        rel="noreferrer"
        class="transition-colors duration-200 hover:text-text"
      >
        Changelog
      </a>
    </div>
  </div>

  <div class="mx-auto w-full max-w-5xl px-6 pb-8 text-xs text-subtle">
    Built by noahtekle. No tracking on this site.
  </div>
</footer>
