---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import FeatureRow from '../components/FeatureRow.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Privacy from '../components/Privacy.astro';
import DiscoverPreview from '../components/DiscoverPreview.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Hero />

  <Section
    eyebrow="What it does"
    heading="One dashboard for everything Claude Code can do."
  >
    <FeatureRow />
  </Section>

  <Section
    eyebrow="How it works"
    heading="Open Bridge. Your stack appears."
    subheading="No setup, no config, no permissions. Bridge reads what's already on your machine."
  >
    <HowItWorks />
  </Section>

  <Section eyebrow="Privacy" heading="Privacy isn't optional.">
    <Privacy />
  </Section>

  <Section
    eyebrow="Discover"
    heading="Curated repos, one click to install."
    subheading="Hand-picked plugins, skills, and tools — verified URLs, real subdirectories. The list grows by PR, not algorithm."
  >
    <DiscoverPreview />
  </Section>

  <Footer />
</Base>
