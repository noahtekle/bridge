{
  "name": "@bridge/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Bridge — Electron desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --dir",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "build:all": "electron-vite build && electron-builder --mac --win --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "rebuild": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bridge/core": "workspace:*",
    "@bridge/ui": "workspace:*",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "framer-motion": "^11.5.4",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.445.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "electron": "32.3.3",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
